# These are built JavaScript and CSS files from Vue.js compilation, not missing source
hifiberry-webui source: source-is-missing */assets/*.js
hifiberry-webui source: source-is-missing */assets/*.css

# configure-webui is a system configuration script that needs full path
hifiberry-webui: command-with-path-in-maintainer-script /usr/sbin/configure-webui *

# configure-webui is a simple utility script, manual page not required
hifiberry-webui: no-manual-page usr/sbin/configure-webui
