# HiFiBerry Web UI and API nginx site
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    # Include all HiFiBerry API proxy configurations
    include /etc/nginx/hifiberry-api.d/*.nginx;

    # Include HiFiBerry Web UI configuration
    include /etc/nginx/hifiberry-webui.nginx;
}
