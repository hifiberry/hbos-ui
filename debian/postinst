#!/bin/bash

set -e

case "$1" in
    configure)
        # $2 contains the old version if this is an upgrade
        if [ -z "$2" ]; then
            echo "Installing HiFiBerry Web UI (fresh install)"
        else
            echo "Upgrading HiFiBerry Web UI from version $2"
        fi
        
        # Create necessary directories
        mkdir -p /var/log/nginx
        mkdir -p /etc/nginx/sites-available
        mkdir -p /etc/nginx/hifiberry-api.d

        # On upgrade, migrate legacy API include files to the API include directory
        if [ -n "$2" ]; then
            for legacy_file in /etc/nginx/hifiberry-*.nginx; do
                [ -e "$legacy_file" ] || continue
                filename=$(basename "$legacy_file")

                # Keep Web UI include in /etc/nginx
                if [ "$filename" = "hifiberry-webui.nginx" ]; then
                    continue
                fi

                mv -f "$legacy_file" /etc/nginx/hifiberry-api.d/"$filename"
                echo "Migrated legacy nginx include: $filename"
            done
        fi
        
        # Always install nginx configuration files from templates
        echo "Installing HiFiBerry nginx configuration files"
        for nginx_file in /usr/share/hifiberry-webui/nginx/*.nginx; do
            if [ -f "$nginx_file" ]; then
                filename=$(basename "$nginx_file")
                if [ "$filename" = "hifiberry-webui.nginx" ]; then
                    cp "$nginx_file" /etc/nginx/"$filename"
                else
                    cp "$nginx_file" /etc/nginx/hifiberry-api.d/"$filename"
                fi
            fi
        done
        
        # Install nginx site configuration
        if [ -f /usr/share/hifiberry-webui/nginx/hifiberry-webui ]; then
            cp /usr/share/hifiberry-webui/nginx/hifiberry-webui /etc/nginx/sites-available/hifiberry-webui
            
            # Enable nginx site
            echo "Enabling HiFiBerry Web UI nginx site"
            ln -sf /etc/nginx/sites-available/hifiberry-webui /etc/nginx/sites-enabled/hifiberry-webui
            
            # Disable default site if it exists
            if [ -L /etc/nginx/sites-enabled/default ]; then
                echo "Disabling default nginx site"
                rm -f /etc/nginx/sites-enabled/default
            fi
            
            # Test and reload nginx
            if nginx -t 2>/dev/null; then
                echo "nginx configuration test passed"
                if systemctl is-active --quiet nginx; then
                    systemctl reload nginx && echo "nginx reloaded successfully"
                fi
            else
                echo "Warning: nginx configuration test failed"
            fi
        fi
        
        echo "HiFiBerry Web UI is now available at http://localhost"
        ;;
    
    abort-upgrade|abort-remove|abort-deconfigure)
        # Nothing to do in these cases
        ;;
    
    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
