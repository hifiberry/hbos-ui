#!/bin/bash

set -e

case "$1" in
    remove|purge)
        echo "Removing HiFiBerry Web UI nginx configuration"
        
        # Disable nginx site
        if [ -L /etc/nginx/sites-enabled/hifiberry-webui ]; then
            echo "Disabling HiFiBerry Web UI nginx site"
            rm -f /etc/nginx/sites-enabled/hifiberry-webui
            
            # Reload nginx if running
            if systemctl is-active --quiet nginx; then
                systemctl reload nginx 2>/dev/null || true
            fi
        fi
        ;;
    
    upgrade|deconfigure)
        echo "Package upgrade or deconfigure - preserving nginx configuration"
        # Don't remove configuration during upgrades
        ;;
    
    failed-upgrade)
        # Nothing to do
        ;;
    
    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
