{
  "name": "hbos-ui",
  "version": "0.19.11",
  "description": "A modern Vue 3 web interface for HiFiBerryOS",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev-expose": "vite --host",
    "dev-server": "vite --config vite.config.dev-server.ts",
    "dev-server-expose": "vite --host --config vite.config.dev-server.ts",
    "device": "vite --mode test-device",
    "device-expose": "vite --host --mode test-device",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "preview-expose": "vite preview --host",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@vueuse/core": "^13.3.0",
    "apexcharts": "^5.3.1",
    "chart.js": "^4.5.0",
    "d3": "^7.9.0",
    "d3-graphviz": "^5.6.0",
    "pinia": "^3.0.1",
    "simple-statistics": "^7.8.8",
    "vue": "^3.5.18",
    "vue-audio-level-meter": "^1.1.8",
    "vue-chartjs": "^5.3.2",
    "vue-inline-svg": "^4.0.1",
    "vue-router": "^4.5.0",
    "vue3-apexcharts": "^1.8.0",
    "vue3-toastify": "^0.2.8"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.1",
    "@types/d3": "^7.4.3",
    "@types/d3-graphviz": "^2.6.10",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "~10.0.0",
    "happy-dom": "^20.7.0",
    "jiti": "^2.4.2",
    "npm-run-all2": "^7.0.2",
    "prettier": "3.5.3",
    "sass-embedded": "^1.89.2",
    "typescript": "~5.8.0",
    "vite": "^6.2.4",
    "vite-plugin-remove-console": "^2.2.0",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.8"
  }
}
